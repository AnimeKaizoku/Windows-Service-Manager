# Normalize line endings; check out native, commit LF.
* text=auto

*.go      text eol=lf
*.js      text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.ps1     text eol=crlf

*.png     binary
*.ico     binary
*.woff2   binary
*.exe     binary
